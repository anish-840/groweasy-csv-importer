# =============================================================================
# GrowEasy CSV Importer — environment reference
# Copy the relevant sections into apps/api/.env and apps/web/.env.local
# =============================================================================

# ---------------------------------------------------------------------------
# Backend (apps/api/.env)
# ---------------------------------------------------------------------------

# Google Gemini API key. Get one free at https://aistudio.google.com/apikey
# Leave blank to run in deterministic "heuristic" fallback mode (no AI).
GEMINI_API_KEY=

# Gemini model to use. gemini-2.5-flash is fast, cheap and on the free tier.
# You can bump this to a newer model (e.g. gemini-2.5-pro) without code changes.
GEMINI_MODEL=gemini-2.5-flash

# Server
PORT=8080
CORS_ORIGIN=*

# Extraction tuning
BATCH_SIZE=20
BATCH_CONCURRENCY=3
MAX_RETRIES=3
MAX_ROWS=10000
MAX_FILE_SIZE_MB=15

# Force the heuristic fallback even if GEMINI_API_KEY is set (useful for demos/tests)
FORCE_FALLBACK=false

# ---------------------------------------------------------------------------
# Frontend (apps/web/.env.local)
# ---------------------------------------------------------------------------

# Base URL of the backend API (no trailing slash)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
