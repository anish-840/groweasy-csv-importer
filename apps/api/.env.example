# Google Gemini API key. Get one free at https://aistudio.google.com/apikey
# Leave blank to run in deterministic "heuristic" fallback mode (no AI).
GEMINI_API_KEY=

# Gemini model (gemini-2.5-flash is fast, cheap, and on the free tier).
GEMINI_MODEL=gemini-2.5-flash

PORT=8080
CORS_ORIGIN=*

BATCH_SIZE=20
BATCH_CONCURRENCY=3
MAX_RETRIES=3
MAX_ROWS=10000
MAX_FILE_SIZE_MB=15

# Force the heuristic fallback even when GEMINI_API_KEY is set (demos / tests).
FORCE_FALLBACK=false
